{
  "name": "@wipsquare/vies-vat-check",
  "version": "1.0.0",
  "description": "TypeScript client for validating EU VAT numbers with the VIES API.",
  "keywords": [
    "vat",
    "vies",
    "eu",
    "tax",
    "validation",
    "typescript",
    "node"
  ],
  "homepage": "https://github.com/wipsquare/vies-vat-check#readme",
  "bugs": {
    "url": "https://github.com/wipsquare/vies-vat-check/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wipsquare/vies-vat-check.git"
  },
  "license": "MIT",
  "author": "wipsquare",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test dist/test/**/*.test.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.5.2",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.2"
  }
}